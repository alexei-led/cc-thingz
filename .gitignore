model-profiles.json
settings.local.json
.claude/settings.local.json
.claude/scheduled_tasks.lock
scripts/.env

# === Settings with permissions (contains allowed URLs/domains) ===
settings.json

# === Session history (may echo sensitive prompts) ===
history.jsonl

