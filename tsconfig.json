{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": [
      "bun-types"
    ],
    "skipLibCheck": true,
    "noEmit": true,
    "strict": false,
    "allowImportingTsExtensions": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": [
    "src/pi-extensions/**/*.ts",
    "src/plugins/pi/extensions/**/*.ts",
    "tests/pi-extensions/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
