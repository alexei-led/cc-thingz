#!/usr/bin/env bash
# Pre-commit: fast checks only — lint, format, secrets on staged files.
# Heavier drift validation and the full test suite run in pre-push.
# Install: make setup (uses core.hooksPath, no copy needed)
set -euo pipefail

echo "=== Pre-commit (fast) ==="

# Fast linters: ruff is sub-second, shellcheck/shfmt only run on staged files
make lint || {
	echo "FAIL: make lint — run 'make fmt' to auto-fix"
	exit 1
}

# Validate canonical sources and Agent Bundler availability.
make validate || {
	echo "FAIL: make validate"
	exit 1
}

# Rebuild when canonical source or Agent Bundler configuration changes.
if git diff --cached --name-only --diff-filter=ACMR | grep -qE '^(src/|agentbundle\.json)'; then
	echo "canonical source/config changed — running 'make build' to refresh dist/"
	make build || {
		echo "FAIL: make build"
		exit 1
	}
	regen_paths=(dist/)
	if ! git diff --quiet -- "${regen_paths[@]}"; then
		git add -- "${regen_paths[@]}"
		echo "re-staged Agent Bundler output under dist/"
	fi
fi

# Secret scan on staged changes only
if command -v gitleaks &>/dev/null; then
	gitleaks git --pre-commit --staged --verbose >/dev/null || {
		echo "FAIL: gitleaks (re-run with --verbose for detail)"
		exit 1
	}
else
	echo "(gitleaks not installed — skipping)"
fi

echo "=== Pre-commit passed (heavier checks run on push) ==="
