#!/usr/bin/env bash
# Create a release tag with automatic version bumping.
#
# Usage: scripts/release/release-tag v1.2.0
#
# This script:
# 1. Validates the version format (vX.Y.Z)
# 2. Bumps versions in Agent Bundler package and project metadata
# 3. Runs `make build` to regenerate dist/
# 4. Updates CHANGELOG.md with a placeholder entry
# 5. Commits the version bump
# 6. Creates an annotated git tag
set -euo pipefail

if [ $# -ne 1 ]; then
	echo "Usage: scripts/release/release-tag <version>"
	echo "Example: scripts/release/release-tag v1.2.0"
	exit 1
fi

TAG="$1"
VERSION="${TAG#v}"

# Validate semver format
if ! [[ "$VERSION" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
	echo "ERROR: '$TAG' is not a valid semver tag (expected vX.Y.Z)"
	exit 1
fi

# Check for clean working tree
if [ -n "$(git status --porcelain)" ]; then
	echo "ERROR: working tree is not clean — commit or stash changes first"
	exit 1
fi

# Check tag doesn't already exist
if git rev-parse "$TAG" &>/dev/null; then
	echo "ERROR: tag '$TAG' already exists"
	exit 1
fi

echo "Bumping versions to $VERSION..."

# Portable in-place sed: BSD sed needs -i '', GNU sed needs -i without ''.
sed_inplace() {
	local expr="$1" file="$2"
	sed -i.release-tag.bak "$expr" "$file"
	rm -f "$file.release-tag.bak"
}

update_agentbundle_version() {
	local path=$1
	local version=$2
	python3 - "$path" "$version" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
version = sys.argv[2]
data = json.loads(path.read_text())
data["distribution"]["version"] = version
for output in data["composition"]:
    aggregate = output.get("aggregate")
    if aggregate is not None:
        aggregate["metadata"]["version"] = version
path.write_text(json.dumps(data, indent=2) + "\n")
PY
}

# Bump Agent Bundler package metadata.
shopt -s nullglob
package_jsons=(src/.agentbundler/packages/*.json)
project_version_files=(
	agentbundle.json
	pyproject.toml
	uv.lock
	package.json
	src/skills/playwright-skill/scripts/package.json
)
shopt -u nullglob
if [ ${#package_jsons[@]} -eq 0 ]; then
	echo "ERROR: no src/.agentbundler/packages/*.json files found"
	exit 1
fi
for f in "${package_jsons[@]}"; do
	sed_inplace 's/"version": "[^"]*"/"version": "'"$VERSION"'"/' "$f"
done
for f in "${project_version_files[@]}"; do
	if [ ! -f "$f" ]; then
		echo "ERROR: expected version file missing: $f"
		exit 1
	fi
	if [[ "$f" == "agentbundle.json" ]]; then
		update_agentbundle_version "$f" "$VERSION"
	elif [[ "$f" == "uv.lock" ]]; then
		uv lock
	elif [[ "$f" == *.toml ]]; then
		sed_inplace "s/^version = .*/version = \"$VERSION\"/" "$f"
	else
		sed_inplace "s/\"version\": \"[^\"]*\"/\"version\": \"$VERSION\"/" "$f"
	fi
done

# Regenerate dist/ and root manifests from the bumped sources
echo "Running 'make build' to regenerate manifests..."
make build

# Stage generated repository-root compatibility outputs when configured. The
# compatibility state is Agent Bundler-owned; reject malformed paths rather than
# allowing a release helper to stage arbitrary repository files.
compatibility_files=()
if [ -f .agentbundler/compatibility.json ]; then
	while IFS= read -r path; do
		compatibility_files+=("$path")
	done < <(
		python3 - <<'PY'
import json
from pathlib import Path

state_path = Path(".agentbundler/compatibility.json")
state = json.loads(state_path.read_text())
allowed_files = {
    ".agents/plugins/marketplace.json",
    ".claude-plugin/marketplace.json",
    ".cursor-plugin/marketplace.json",
    ".github/plugin/marketplace.json",
}
paths = [str(state_path)]
for path in state.get("files", []):
    candidate = Path(path)
    if (
        candidate.is_absolute()
        or ".." in candidate.parts
        or not (
            path in allowed_files
            or path.startswith(".codex/agents/") and candidate.suffix == ".toml"
        )
    ):
        raise SystemExit(f"invalid compatibility output path: {path}")
    paths.append(path)
if state.get("pi", {}).get("legacyPeerDeps"):
    paths.append(".npmrc")
for path in paths:
    print(path)
PY
	)
fi

# Add CHANGELOG entry if not already present
if ! grep -q "\[$VERSION\]" CHANGELOG.md; then
	DATE=$(date +%Y-%m-%d)
	python3 - "$VERSION" "$DATE" <<'PY'
from pathlib import Path
import sys

version, date = sys.argv[1:3]
path = Path("CHANGELOG.md")
text = path.read_text()
marker = "## [Unreleased]\n"
entry = f"\n## [{version}] - {date}\n\n"
if marker not in text:
    raise SystemExit("CHANGELOG.md missing ## [Unreleased] marker")
path.write_text(text.replace(marker, marker + entry, 1))
PY
	echo "Added CHANGELOG entry for $VERSION — edit it before pushing."
fi

# Show what changed
echo ""
echo "Version bumped to $VERSION in:"
git diff --name-only | sed 's/^/  /'
echo ""

# Commit and tag
git add \
	"${package_jsons[@]}" \
	"${project_version_files[@]}" \
	dist/ \
	CHANGELOG.md \
	"${compatibility_files[@]}"
git commit -m "chore: bump version to $VERSION"
git tag -a "$TAG" -m "Release $VERSION"

echo ""
echo "Created tag $TAG"
echo "Push with: git push origin master $TAG"
